# Site URL (used for Xendit redirect URLs and Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Xendit Payment Integration
# Get your Secret API Key from: https://dashboard.xendit.co/settings/developers#api-keys
XENDIT_SECRET_KEY=xnd_development_your_secret_key_here

# Optional: Webhook verification token (set the same value in Xendit Dashboard > Webhooks)
# Webhook URL: https://your-domain.com/api/webhooks/xendit
XENDIT_WEBHOOK_TOKEN=your_webhook_verification_token
